# Istiqtab reverse proxy.
# Local dev: serves http://localhost and proxies to the web container.
# Production: replace `:80` with your domain (e.g. istiqtab.ma) and Caddy
# will provision TLS automatically.

:80 {
	encode gzip
	reverse_proxy web:3000
}

# Production example (uncomment + set domain):
# istiqtab.ma {
# 	encode gzip
# 	reverse_proxy web:3000
# }
