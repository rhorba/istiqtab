# Database
DATABASE_URL=postgresql://istiqtab_app:changeme@localhost:5432/istiqtab

# Auth.js
NEXTAUTH_SECRET=changeme-minimum-32-chars-long-secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth (required — B2B investors use LinkedIn)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# AI — server-side only, never expose to client
ANTHROPIC_API_KEY=sk-ant-...

# Email
RESEND_API_KEY=re_...

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PRIVATE_BUCKET=istiqtab-private
R2_PUBLIC_BUCKET=istiqtab-public
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Postgres (internal — for pg-boss worker)
POSTGRES_DB=istiqtab
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
