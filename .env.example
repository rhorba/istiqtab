# Istiqtab — environment template for the Docker stack.
# Copy to `.env` (gitignored) and fill secrets before `docker compose up -d`.
# For local `pnpm dev` outside Docker, see apps/web/.env.example.

# ── Database ──────────────────────────────────────────────────────────────────
# App role connection (RLS-enforced). Inside compose the host is "postgres".
DATABASE_URL=postgresql://istiqtab_app:changeme@postgres:5432/istiqtab

# Postgres superuser — used by the postgres container init hook and the migrate
# service to apply RLS policies. The SUPERUSER_URL is auto-derived in compose
# from the vars below; only override if your setup differs.
POSTGRES_DB=istiqtab
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Host port for postgres (change if 5432 is taken by another project)
POSTGRES_HOST_PORT=5432

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Must be ≥ 32 chars. Generate: openssl rand -hex 32
NEXTAUTH_SECRET=changeme-minimum-32-chars-long-secret-here

# Public URL of the app (the Caddy proxy, not the Node server directly).
# Use your actual domain in production, e.g. https://istiqtab.ma
NEXTAUTH_URL=http://localhost

# Google OAuth — https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth (required — B2B investors strongly prefer LinkedIn login)
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── AI — server-side only, never exposed to the client ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PRIVATE_BUCKET=istiqtab-private
R2_PUBLIC_BUCKET=istiqtab-public
# Public CDN URL of the public R2 bucket (expert photos etc.)
R2_PUBLIC_URL=https://pub-xxx.r2.dev
