# Istiqtab — root environment template for the Docker stack.
# Copy to `.env` (gitignored) and fill in real secrets before `docker compose up -d`.
# For local `pnpm dev` outside Docker, see apps/web/.env.example.

# ── Database ──────────────────────────────────────────────────────────────────
# App connection (RLS-bound role). Inside compose, host = postgres.
DATABASE_URL=postgresql://istiqtab_app:changeme@postgres:5432/istiqtab

# Superuser bootstrap (used by the postgres container only)
POSTGRES_DB=istiqtab
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# ── Auth.js ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=changeme-minimum-32-chars-long-secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth (required — B2B investors use LinkedIn)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── AI — server-side only, never exposed to the client ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PRIVATE_BUCKET=istiqtab-private
R2_PUBLIC_BUCKET=istiqtab-public
R2_PUBLIC_URL=https://pub-xxx.r2.dev
